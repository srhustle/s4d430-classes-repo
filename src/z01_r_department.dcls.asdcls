@EndUserText.label: 'Z01_R_DEPARTMENT ACCESS CONTROL'
@MappingRole: true
define role Z01_R_DEPARTMENT {
    grant 
        select
            on
                Z01_R_DEPARTMENT
                    where
                        ( Id ) = aspect pfcg_auth( 
                            /LRN/DPMNT, 
                            /LRN/DPMNT, 
                            ACTVT = '03'
                        );
                        
}